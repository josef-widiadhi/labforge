# 🔒 HARDENING: Never commit real .env files — this is an EXAMPLE only
# Generate strong random values for all secrets:
#   openssl rand -hex 32

POSTGRES_DB=securedb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_RANDOM_PASSWORD_32_CHARS

REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_RANDOM_PASSWORD

# Min 256-bit (32 bytes hex = 64 chars)
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_FROM_OPENSSL_RAND_HEX_32
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_HEX_SECRET

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

NODE_ENV=production
